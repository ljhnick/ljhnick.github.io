---
import type { CollectionEntry } from "astro:content";

interface Props {
  item: CollectionEntry<"news">;
}

const { item } = Astro.props;
const { Content } = await item.render();

const d = item.data.date;
const dateStr = d.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<li class="grid grid-cols-[110px_1fr] gap-4 py-2.5 text-sm border-b divider last:border-b-0">
  <time class="muted tabular-nums pt-0.5" datetime={d.toISOString()}>{dateStr}</time>
  <div class="news-body leading-relaxed">
    <Content />
  </div>
</li>

<style is:global>
  .news-body p {
    margin: 0;
  }
  .news-body strong {
    color: var(--fg);
  }
</style>
