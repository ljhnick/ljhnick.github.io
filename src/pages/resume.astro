---
import { getEntry } from "astro:content";

const resume = await getEntry("resume", "resume");
const d = resume.data;

// Minimal inline formatting for user content: escape HTML, then
// [text](url) links and **bold**.
function fmt(s: string): string {
  return s
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(
      /\[([^\]]+)\]\(([^)]+)\)/g,
      '<a href="$2" target="_blank" rel="noopener">$1</a>',
    )
    .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>");
}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{d.name} — Resume</title>
  <style>
    :root {
      --ink: #111;
      --muted: #777;
      --faint: #999;
      --maxw: 720px;
    }
    * { box-sizing: border-box; }
    html { -webkit-text-size-adjust: 100%; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", Helvetica, Arial, sans-serif;
      color: var(--ink);
      background: #f4f4f4;
      margin: 0;
      line-height: 1.55;
      font-size: 14.5px;
      -webkit-font-smoothing: antialiased;
    }
    .sheet { max-width: var(--maxw); margin: 32px auto; background: #fff; padding: 56px 60px 60px; }

    header { margin-bottom: 34px; }
    h1 { font-size: 24px; font-weight: 600; letter-spacing: -0.01em; margin: 0 0 4px; }
    .role { font-size: 14.5px; color: var(--muted); margin: 0 0 12px; }
    .contact { font-size: 13px; color: var(--muted); display: flex; flex-wrap: wrap; gap: 4px 12px; }
    .contact a { color: var(--muted); text-decoration: none; }
    .contact a:hover { color: var(--ink); }
    .contact .sep { color: var(--faint); }

    section { margin-top: 30px; }
    h2 { font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--faint); margin: 0 0 14px; }
    .lead { margin: 0; color: #333; }
    .more { margin: 12px 0 0; font-size: 13px; }
    .more a { color: var(--muted); text-decoration: none; }
    .more a:hover { color: var(--ink); }

    .entry { margin-bottom: 16px; }
    .entry:last-child { margin-bottom: 0; }
    .entry-head { display: flex; justify-content: space-between; align-items: baseline; gap: 16px; }
    .entry-title { font-weight: 600; }
    .entry-org { color: var(--muted); font-style: italic; }
    .entry-sep { color: var(--muted); }
    .entry-date { font-size: 13px; color: var(--faint); white-space: nowrap; font-variant-numeric: tabular-nums; }
    .entry-detail { font-size: 13.5px; color: var(--muted); margin-top: 2px; }
    ul.bullets { margin: 5px 0 0; padding-left: 0; list-style: none; }
    ul.bullets li { font-size: 13.5px; color: var(--muted); margin-bottom: 3px; padding-left: 16px; position: relative; }
    ul.bullets li::before {
      content: "";
      position: absolute;
      left: 3px;
      top: 0.62em;
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: var(--faint);
    }
    ul.bullets li:last-child { margin-bottom: 0; }
    ul.bullets :global(strong) { color: var(--ink); font-weight: 600; }
    /* Inline links inside user content (bullets, items, text) */
    .lead :global(a), .entry-detail :global(a), ul.bullets :global(a), ol.items :global(a) {
      color: inherit;
      text-decoration: underline;
      text-decoration-color: #ccc;
      text-underline-offset: 2px;
    }
    .lead :global(a:hover), .entry-detail :global(a:hover), ul.bullets :global(a:hover), ol.items :global(a:hover) {
      text-decoration-color: var(--ink);
    }

    ol.items { list-style: none; margin: 0; padding: 0; }
    ol.items li { margin-bottom: 13px; font-size: 13.5px; line-height: 1.5; color: #333; }
    ol.items li:last-child { margin-bottom: 0; }
    ol.items :global(strong) { color: var(--ink); font-weight: 600; }

    .toolbar { position: fixed; top: 22px; right: 24px; z-index: 10; }
    .btn { font: inherit; font-size: 12.5px; color: var(--faint); background: none; border: none; padding: 0; cursor: pointer; letter-spacing: 0.01em; text-decoration: none; }
    .btn:hover { color: var(--ink); }

    @page { size: Letter; margin: 16mm 18mm; }
    @media print {
      body { background: #fff; font-size: 10.5pt; }
      .sheet { max-width: none; margin: 0; padding: 0; }
      .toolbar { display: none !important; }
      a { color: var(--ink); }
      h1 { font-size: 19pt; }
      section { margin-top: 18pt; }
      .entry, ol.items li { break-inside: avoid; }
      h2 { break-after: avoid; }
    }
  </style>
</head>
<body>
  <div class="toolbar">
    <button class="btn" onclick="window.print()" title="Opens the print dialog — choose “Save as PDF”">↓ PDF</button>
  </div>

  <div class="sheet">
    <header>
      <h1>{d.name}</h1>
      {d.role && <p class="role">{d.role}</p>}
      {d.contacts && (
        <div class="contact">
          {d.contacts.map((c, i) => (
            <>
              {i > 0 && <span class="sep">/</span>}
              <a href={c.href}>{c.label}</a>
            </>
          ))}
        </div>
      )}
    </header>

    {d.sections.map((s) => (
      <section>
        <h2>{s.title}</h2>

        {s.text && <p class="lead" set:html={fmt(s.text)} />}

        {s.entries && s.entries.map((e) => (
          <div class="entry">
            <div class="entry-head">
              <span>
                <span class="entry-title">{e.org}</span>
                {e.title && <> <span class="entry-org">{e.title}</span></>}
              </span>
              {e.date && <span class="entry-date">{e.date}</span>}
            </div>
            {e.detail && <div class="entry-detail" set:html={fmt(e.detail)} />}
            {e.bullets && (
              <ul class="bullets">
                {e.bullets.map((b) => <li set:html={fmt(b)} />)}
              </ul>
            )}
          </div>
        ))}

        {s.items && (
          <ol class="items">
            {s.items.map((it) => <li set:html={fmt(it)} />)}
          </ol>
        )}

        {s.link && (
          <p class="more"><a href={s.link.href}>{s.link.label}</a></p>
        )}
      </section>
    ))}
  </div>
</body>
</html>
